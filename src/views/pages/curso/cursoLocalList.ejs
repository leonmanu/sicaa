<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <%- include('../../partials/head') %>
    <title>SICAA - Mis Cursos</title>
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">
    <style>
        #tablaCursosCargo td,
        #tablaCursosCargo th {
            vertical-align: middle;
        }
        .flatpickr-input.flatpickr-mobile,
.flatpickr-input[readonly] {
    pointer-events: none;
}
.flatpickr-input.flatpickr-input ~ input {
    pointer-events: auto;
}
        .dropdown-formadores {
            max-height: 260px;
            overflow-y: auto;
        }

        @media (max-width: 767.98px) {
            .container.py-5 {
                padding-top: 1rem !important;
                padding-bottom: 1rem !important;
            }

            #btnAltaCurso {
                width: 100%;
            }

            #tablaCursosCargo {
                min-width: 760px;
            }

            #tablaCursosCargo .btn-group {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 0.35rem;
            }

            #tablaCursosCargo .btn-group .btn {
                font-size: 0.8rem;
                padding: 0.3rem 0.4rem;
                width: 100%;
            }

            #modalSeleccionarBase .sticky-top {
                position: static !important;
            }

            #modalAltaCurso .col-6,
            #modalAltaCurso .col-8,
            #modalAltaCurso .col-4 {
                width: 100%;
            }

            #modalAltaCurso .form-control,
            #modalAltaCurso .form-select,
            #modalSeleccionarBase .form-control,
            #modalSeleccionarBase .form-select {
                font-size: 16px;
            }

            #modalAltaCurso .modal-footer {
                flex-direction: column-reverse;
                gap: 0.5rem;
            }

            #modalAltaCurso .modal-footer .btn {
                width: 100%;
            }

            #modalAltaCurso .dropdown-formadores,
            #modalSeleccionarBase .dropdown-formadores {
                left: 0;
                right: 0;
                min-width: 100% !important;
            }
        }
    </style>
</head>
<body>
    <%- include('../../partials/navbar') %>
    <%- include('../../partials/msj') %>

    <div class="container py-5">
        <div class="row mb-4">
            <div class="col-md-8">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2">
                        <li class="breadcrumb-item"><a href="/usuario/mis-cargos" class="text-decoration-none">Mis Cargos</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Gestión de Cursos</li>
                    </ol>
                </nav>
                <h2 class="fw-bold mb-1">
                    <i class="bi bi-journal-bookmark-fill me-2 text-primary"></i>
                    <%= cargo?.areaId?.nombre || 'Área General' %> * <small><% formador = cargo?.ocupante?.usuarioId?.referenciaId?.apellido+', '+cargo?.ocupante?.usuarioId?.referenciaId?.nombre %></small>
                </h2>
                <p class="text-muted mb-0">
                    <span class="badge bg-secondary me-2"><%=ciieClave%> <%= cargo.ciieId?.nombre || '' %></span>
                    <span class="badge bg-outline-info border border-info text-info">Clave Cargo: <%= cargo.clave %></span>
                </p>
            </div>
            <div class="col-md-4 text-md-end d-flex align-items-end justify-content-md-end mt-3 mt-md-0">
                <button id="btnAltaCurso" class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#modalSeleccionarBase">
                    <i class="bi bi-plus-circle me-1"></i> Alta de curso
                </button>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-dark border-secondary shadow-sm">
                    <div class="card-body py-2 px-3">
                        <small class="text-muted text-uppercase d-block" style="font-size: 0.7rem;">Cursos vinculados</small>
                        <span class="h4 fw-bold mb-0"><%= cursosLocales.length %></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 bg-dark text-white">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="tablaCursosCargo"
                           class="table table-dark table-hover align-middle mb-0"
                           data-estado-col-index="<%= usuario.tipo === 'institucion' ? 4 : 3 %>"
                           data-creado-col-index="<%= usuario.tipo === 'institucion' ? 5 : 4 %>"
                           data-inicio-col-index="<%= usuario.tipo === 'institucion' ? 3 : 2 %>">
                        <thead class="bg-black text-muted small text-uppercase">
                            <tr>
                                <th>Iti</th>
                                <% if(usuario.tipo == 'institucion'){ %>
                                    <th>Área</th>
                                <% } %>
                                <th>Propuesta</th>
                                <th>Inicio</th>
                                <th>Dispositivo</th>
                                <th>Creado</th>
                                <th class="text-center pe-4">Acciones</th>
                            </tr>
                            <tr class="bg-dark text-white">
                                <th>
                                    <select class="form-select form-select-sm filtro-columna" data-column="0">
                                        <option value="">Todos</option>
                                    </select>
                                </th>
                                <% if(usuario.tipo == 'institucion'){ %>
                                    <th>
                                        <select class="form-select form-select-sm filtro-columna" data-column="1">
                                            <option value="">Todas</option>
                                        </select>
                                    </th>
                                <% } %>
                                <th>
                                    <input type="text" class="form-control form-control-sm filtro-texto" data-column="<%= usuario.tipo == 'institucion' ? 2 : 1 %>" placeholder="Buscar...">
                                </th>
                                <th>
                                    <select class="form-select form-select-sm filtro-columna" data-column="<%= usuario.tipo == 'institucion' ? 3 : 2 %>">
                                        <option value="">Todos</option>
                                    </select>
                                </th>
                                <th>
                                    <select class="form-select form-select-sm filtro-columna" data-column="<%= usuario.tipo == 'institucion' ? 4 : 3 %>">
                                        <option value="">Todos</option>
                                    </select>
                                </th>
                                <th>
                                    <select class="form-select form-select-sm filtro-columna" data-column="<%= usuario.tipo == 'institucion' ? 5 : 4 %>">
                                        <option value="">Todos</option>
                                    </select>
                                </th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (cursosLocales && cursosLocales.length > 0) { %>
                                <% cursosLocales.forEach(c => { %>
                                    <tr>
                                        <td class="fw-bold text-info"><%= c.anio %> • I<%= c.itinerario %></td>
                                        <% if(usuario.tipo == 'institucion'){ %>
                                            <td>
                                                <b><%= c.cargoId.areaId?.nombreCorto || 'Área General' %></b> <small><%= c.cargoId?.clave || 'clave fallida' %></small>
                                                <br>
                                                <small><%= c.formadorAbc %></small>
                                            </td>
                                        <% } %>
                                        <td>
                                            <div class="text-wrap" style="max-width: 400px;"><%= c.nombrePropuesta %></div>
                                        </td>

                                            <td data-order="<%= c.encuentros && c.encuentros.length > 0 ? new Date(c.encuentros[0].fecha).toISOString() : '' %>">
                                                <% if (c.encuentros && c.encuentros.length > 0) { %>
                                                    <small class="text-muted">
                                                        <% const fecha = new Date(c.encuentros[0].fecha); %>
                                                        <% const opciones = { month: '2-digit', day: '2-digit' }; %>
                                                        <%= fecha.toLocaleDateString('es-AR', opciones) %>
                                                    </small>
                                                <% } else { %>
                                                    <small class="text-muted">-</small>
                                                <% } %>
                                            </td>

                                        <td data-order="<%= c.estado === 'pendiente' ? 0 : c.estado === 'vinculado' ? 1 : c.estado === 'modificacion_pendiente' ? 2 : c.estado === 'eliminacion_pendiente' ? 3 : c.estado === 'dormido' ? 4 : 99 %>">
                                            <small class="text-muted"><%= c.dispositivo %></small>
                                            <br>
                                            <% 
                                                const coloresEstado = {
                                                    'pendiente': 'bg-warning text-dark',
                                                    'vinculado': 'bg-success',
                                                    'modificacion_pendiente': 'bg-info text-dark',
                                                    'eliminacion_pendiente': 'bg-danger',
                                                    'dormido': 'bg-secondary'
                                                };

                                                const etiquetasEstado = {
                                                    'pendiente': 'Pendiente',
                                                    'vinculado': 'Vinculado',
                                                    'modificacion_pendiente': 'Modif. Pendiente',
                                                    'eliminacion_pendiente': 'Baja Pendiente',
                                                    'dormido': 'Dormido'
                                                };
                                                %>
                                            <div class="mb-1">
                                                <span class="badge rounded-pill <%= coloresEstado[c.estado] || 'bg-light text-dark' %>" style="font-size: 0.7rem;">
                                                    <%= etiquetasEstado[c.estado] || c.estado %>
                                                </span>
                                            </div>
                                        </td>
                                        <td data-order="<%= c.createdAt ? new Date(c.createdAt).toISOString() : '' %>">
                                            <small class="text-muted"><%= c.createdAt ? new Date(c.createdAt).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: '2-digit' }) : '-' %></small>
                                        </td>
                                        <td class="text-center pe-4">
                                            <% if (c.estado === 'vinculado') { %>
    <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" 
                type="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-three-dots-vertical"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end bg-dark border-secondary">
            <li>
                <a class="dropdown-item text-white" href="/inscripto/curso/<%= c.idOfertaOficial %>">
                    <i class="bi bi-people-fill me-2 text-primary"></i>Ver alumnos
                </a>
            </li>
            <li>
                <button class="dropdown-item text-white" onclick="copyToClipboard('<%= c.enlaceInscripcion %>')">
                    <i class="bi bi-link-45deg me-2 text-info"></i>Copiar enlace
                </button>
            </li>
            <li>
                <a class="dropdown-item text-white" href="/curso/flyer/<%= c.idOfertaOficial %>" target="_blank">
                    <i class="bi bi-image me-2 text-warning"></i>Ver flyer
                </a>
            </li>
            <li><hr class="dropdown-divider border-secondary"></li>
            <li>
                <button class="dropdown-item text-success btn-editar-pendiente" 
                        data-id="<%= c._id %>">
                    <i class="bi bi-pencil me-2"></i>Editar
                </button>
            </li>
            <li>
                <button class="dropdown-item text-danger btn-eliminar-pendiente" 
                        data-id="<%= c._id %>">
                    <i class="bi bi-trash me-2"></i>Eliminar
                </button>
            </li>
        </ul>
    </div>
<% } else { %>
    <div class="dropdown">
        <button class="btn btn-sm btn-outline-warning dropdown-toggle" 
                type="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-three-dots-vertical"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end bg-dark border-secondary">
            <% if (usuario.tipo === 'institucion' && c.estado === 'pendiente') { %>
            <li>
                <button class="dropdown-item text-primary btn-vincular-oficial" 
                        data-curso-clave="<%= c.clave %>">
                    <i class="bi bi-link-45deg me-2"></i>Vincular al sitio oficial 
                </button>
            </li>
            <li><hr class="dropdown-divider border-secondary"></li>
            <% } %>
            <li>
                <button class="dropdown-item text-success btn-editar-pendiente" 
                        data-id="<%= c._id %>">
                    <i class="bi bi-pencil me-2"></i>Editar
                </button>
            </li>
            <li>
                <button class="dropdown-item text-danger btn-eliminar-pendiente" 
                        data-id="<%= c._id %>">
                    <i class="bi bi-trash me-2"></i>Eliminar
                </button>
            </li>
        </ul>
    </div>
<% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="<%= usuario.tipo === 'institucion' ? 8 : 7 %>" class="text-center py-5">
                                        <p class="text-muted mb-0">No hay cursos vinculados a este cargo.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL PASO 1 -->
    <div class="modal fade" id="modalSeleccionarBase" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-scrollable modal-fullscreen-sm-down">
            <div class="modal-content bg-dark border-primary">
                <div class="modal-header bg-primary bg-opacity-10 border-primary">
                    <div>
                        <h5 class="modal-title fw-bold mb-0"><i class="bi bi-archive me-2"></i>Seleccioná un Curso Base</h5>
                        <small class="text-muted">Paso 1 de 2</small>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="p-3 border-bottom border-secondary sticky-top bg-dark">
                        <input type="text" id="buscarCursoBase"
                            class="form-control bg-dark border-secondary text-white mb-2"
                            placeholder="Buscar por nombre, dispositivo o área...">
                        <div id="wrapperFiltros" class="d-none">
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <select id="filtroDispositivo" class="form-select form-select-sm bg-dark border-secondary text-white">
                                        <option value="">Todos los dispositivos</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <select id="filtroArea" class="form-select form-select-sm bg-dark border-secondary text-white">
                                        <option value="">Todas las áreas</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <select id="filtroAnio" class="form-select form-select-sm bg-dark border-secondary text-white">
                                        <option value="">Todos los años</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="estadoCargando" class="text-center py-5">
                        <div class="spinner-border text-primary mb-3" role="status"></div>
                        <div class="text-muted small">Cargando cursos base...</div>
                    </div>
                    <div id="estadoError" class="text-center py-5 d-none">
                        <i class="bi bi-exclamation-circle text-danger fs-3 mb-2 d-block"></i>
                        <div class="text-muted small">No se pudieron cargar los cursos base.</div>
                        <button class="btn btn-sm btn-outline-primary mt-3" id="btnReintentar">Reintentar</button>
                    </div>
                    <div class="list-group list-group-flush d-none" id="listaCursosBase"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL PASO 2 -->
    <div class="modal fade" id="modalAltaCurso" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content bg-dark border-success">
                <div class="modal-header bg-success bg-opacity-10 border-success">
                    <div>
                        <h5 class="modal-title fw-bold mb-0"><i class="bi bi-plus-circle me-2"></i>Nueva Oferta</h5>
                        <small class="text-muted">Paso 2 de 2</small>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-dark border border-primary mb-4 p-3">
                        <div class="fw-bold text-white" id="resumenNombreBase"></div>
                        <small class="text-muted" id="resumenDetalleBase"></small>
                    </div>

                    <input type="hidden" id="cursoBaseId" name="cursoBaseId">
                    <input type="hidden" id="idCursoOriginal" name="idCursoOriginal">
                    <input type="hidden" id="nombrePropuesta" name="nombrePropuesta">
                    <input type="hidden" id="dispositivo" name="dispositivo">
                    <input type="hidden" id="dispositivoSeleccionado">
                    <input type="hidden" id="cursoIdParaEditar"> <!-- ID del curso pendiente que estamos editando -->
                    <input type="hidden" id="cargoId" name="cargoId" value="<%= cargo._id %>">
                    <input type="hidden" id="ciieId" name="ciieId" value="<%= cargo.ciieId?._id || '' %>">
                    <input type="hidden" id="creadoPor" name="creadoPor" value="<%= usuario?.email || '' %>">

                    <div class="row g-3">

                        <div class="col-6">
                            <label class="form-label small fw-bold">AÑO <span class="text-danger">*</span></label>
                            <input type="number" class="form-control bg-dark border-secondary text-white"
                                   id="anio" name="anio" value="<%= new Date().getFullYear() %>" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">ITINERARIO <span class="text-danger">*</span></label>
                            <input type="number" class="form-control bg-dark border-secondary text-white"
                                   id="itinerario" name="itinerario" value="1" min="1">
                        </div>

                        <div class="col-6">
                            <label class="form-label small fw-bold">FORMATO DICTADO <span class="text-danger">*</span></label>
                            <select id="drupalFormatoDictado" name="drupalFormatoDictado"
                                    class="form-select bg-dark border-secondary text-white" required>
                                <option value="Presencial (237)">Presencial</option>
                                <option value="Sincrónico (238)">Bimodal / Sincrónico</option>
                                <option value="Virtual (236)">Virtual</option>
                                <option value="Asincrónico (239)">Asincrónico</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">HORA (todos los encuentros) <span class="text-danger">*</span></label>
                            <input type="time" class="form-control bg-dark border-secondary text-white"
                                   id="horaEncuentro" name="horaEncuentro" value="18:00" required>
                        </div>

                        <div class="col-6">
                            <label class="form-label small fw-bold">ENCUENTROS <span class="text-danger">*</span></label>
                            <input type="number" class="form-control bg-dark border-secondary text-white"
                                   id="cantidadEncuentros" name="cantidadEncuentros" min="1" value="" required readonly>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">FECHAS DE ENCUENTROS <span class="text-danger">*</span></label>
                            <div id="listaFechasEncuentros" class="d-grid gap-2"></div>
                            <button type="button" class="btn btn-sm btn-outline-warning mt-2" id="btnAgregarFechaEncuentro">
                                <i class="bi bi-calendar-plus me-1"></i>Agregar fecha
                            </button>
                        </div>
                        

                        <!-- BLOQUE FORMADORES -->
                        <div class="col-12" id="bloqueFormadores">
                            <label class="form-label small fw-bold mb-1">FORMADOR/A <span class="text-danger">*</span></label>

                            <div id="listaFormadores">
                                <!-- Formador principal -->
                                <div class="formador-row mb-1" data-index="0" data-cargo-id="">
                                    <input type="text"
                                           class="form-control form-control-sm bg-dark border-secondary text-white input-formador"
                                           id="formadorAbc" name="formadorAbc"
                                           maxlength="40" placeholder="Apellido, Nombre"
                                           value="<%= formador %>" required>
                                </div>
                            </div>
 <!-- Selector de alcance: oculto hasta agregar primer invitado -->
                            <div id="wrapperAlcance" class="d-none mb-2">
                                <div class="btn-group btn-group-sm w-100" role="group">
                                    <input type="radio" class="btn-check" name="alcanceFormadores" id="alcanceLocal" value="local" checked>
                                    <label class="btn btn-outline-secondary" for="alcanceLocal">Este CIIE</label>
                                    <input type="radio" class="btn-check" name="alcanceFormadores" id="alcanceRegional" value="regional">
                                    <label class="btn btn-outline-secondary" for="alcanceRegional">Regional</label>
                                    <input type="radio" class="btn-check" name="alcanceFormadores" id="alcanceTodos" value="todos">
                                    <label class="btn btn-outline-secondary" for="alcanceTodos">Todos</label>
                                </div>
                            </div>
                            <!-- Botón invitar: debajo del input principal -->
                            <div class="mt-1 mb-1">
                                <button type="button" id="btnAgregarFormador"
                                        class="btn btn-sm btn-outline-info py-0 px-2"
                                        style="font-size: 0.75rem;">
                                    <i class="bi bi-person-plus me-1"></i>+ Invitado
                                </button>
                            </div>

                           

                            <div id="wrapperCharCount" class="d-none mt-1">
                                <div class="d-flex justify-content-between mb-1" style="font-size: 0.7rem;">
                                    <span class="text-muted">Caracteres usados al combinar</span>
                                    <span id="charCountLabel" class="fw-bold">0 / 40</span>
                                </div>
                                <div class="progress" style="height: 4px;">
                                    <div id="charCountBar" class="progress-bar bg-success" role="progressbar" style="width: 0%"></div>
                                </div>
                                <div id="charCountWarning" class="text-danger d-none mt-1" style="font-size: 0.7rem;">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Superaste el límite de 40 caracteres.
                                </div>
                            </div>
                        </div>

                        <hr>

                        <!-- ACORDEÓN -->
                        <div class="col-12 mt-2">
                            <div class="accordion" id="acordeonCamposOpcionalesCurso">
                                <div class="accordion-item bg-dark border-secondary">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed bg-dark text-white"
                                                type="button" data-bs-toggle="collapse"
                                                data-bs-target="#collapseDrupalCurso">
                                            <b>MÁS DATOS...</b>
                                        </button>
                                    </h2>
                                    <div id="collapseDrupalCurso" class="accordion-collapse collapse"
                                         data-bs-parent="#acordeonCamposOpcionalesCurso">
                                        <div class="accordion-body">
                                            <div class="row g-3">
                                                
                                                <div class="col-6">
                                                    <label class="form-label small fw-bold">HORAS <span class="text-danger">*</span></label>
                                                    <input type="number" class="form-control bg-dark border-secondary text-white"
                                                           id="cantidadHoras" name="cantidadHoras" min="1" value="" required>
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label small fw-bold">CUPO <span class="text-danger">*</span></label>
                                                    <input type="number" class="form-control bg-dark border-secondary text-white"
                                                           id="cupo" name="cupo" min="1" value="30" required>
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label small fw-bold">PUNTAJE</label>
                                                    <input type="number" id="drupalPuntaje"
                                                           class="form-control bg-dark border-secondary text-white"
                                                           step="0.01" min="0">
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label small fw-bold">DÍA DICTADO <span class="text-danger">*</span></label>
                                                    <select id="drupalDiaDictado" name="drupalDiaDictado"
                                                            class="form-select bg-dark border-secondary text-white" required>
                                                        <option value="Lunes">Lunes</option>
                                                        <option value="Martes">Martes</option>
                                                        <option value="Miércoles">Miércoles</option>
                                                        <option value="Jueves">Jueves</option>
                                                        <option value="Viernes">Viernes</option>
                                                        <option value="Sábado">Sábado</option>
                                                    </select>
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label small fw-bold">NIVEL <span class="text-danger">*</span> <small>Destinatarios</small></label>
                                                    <%= cargo?.areaId?.nivel || '' %>
                                                    <input type="text" id="drupalNivel"
                                                           class="form-control bg-dark border-secondary text-white"
                                                           maxlength="120" value="<%= cargo?.areaId?.nivel || '' %>" required>
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label small fw-bold">ALCANCE <span class="text-danger">*</span></label>
                                                    <select id="alcance" name="alcance"
                                                            class="form-select bg-dark border-secondary text-white" required>
                                                        <option value="1" selected>Este CIIE</option>
                                                        <option value="2">Regional</option>
                                                    </select>
                                                </div>
                                                <div class="col-12">
                                                    <label class="form-label small fw-bold">TÍTULO FORMULARIO</label>
                                                    <input type="text" class="form-control bg-dark border-secondary text-white"
                                                           id="tituloFormulario" name="tituloFormulario" maxlength="200">
                                                </div>
                                                <div class="col-8">
                                                    <label class="form-label small fw-bold">SEDE <span class="text-danger">*</span></label>
                                                    <input type="text" id="drupalSede"
                                                           class="form-control bg-dark border-secondary text-white"
                                                           maxlength="120"
                                                           value="CIIE G. de Laferrere - Monseñor López May N° 3250" required>
                                                </div>
                                                <div class="col-4">
                                                    <label class="form-label small fw-bold">ORGANIZA <span class="text-danger">*</span></label>
                                                    <input type="text" id="drupalOrganiza"
                                                           class="form-control bg-dark border-secondary text-white"
                                                           maxlength="120" value="DFDP" required>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div><!-- /row -->
                </div><!-- /modal-body -->

                <div class="modal-footer border-success">
                    <button type="button" class="btn btn-outline-secondary" id="btnVolver">
                        <i class="bi bi-arrow-left me-1"></i>Volver
                    </button>
                    <button type="button" class="btn btn-success fw-bold px-4" id="btnGuardarCurso">
                        <i class="bi bi-check-circle me-1"></i>Crear Curso
                    </button>
                </div>
            </div>
        </div>
    </div>

    <%- include('../../partials/scripts') %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>
    <script>
    $(document).ready(function () {
        const formadorOriginal = "<%= formador %>";
        // Evento para el botón de Alta de curso
$('#btnAltaCurso').on('click', function() {
    // 1. Limpiamos el ID de edición para que el sistema sepa que es un ALTA
    $('#cursoIdParaEditar').val('');
    
    // 2. Reseteamos el formulario (esto limpia casi todo)
    // Suponiendo que tus inputs están dentro de un contenedor o los limpias manualmente:
    $('#modalAltaCurso input:not([type=hidden])').val('');
    $('#modalAltaCurso select').prop('selectedIndex', 0);
    
    // 3. Restauramos los valores por defecto que NO deben estar vacíos
    $('#anio').val(new Date().getFullYear());
    $('#itinerario').val('1');
    $('#horaEncuentro').val('18:00');
    $('#cupo').val('30');
    $('#drupalNivel').val('<%= cargo?.areaId?.nivel || "" %>');
    $('#drupalSede').val('CIIE G. de Laferrere - Monseñor López May N° 3250');
    $('#drupalOrganiza').val('DFDP');
    $('#drupalFormatoDictado').val('Presencial (237)');
    
    // 4. RESTAURAMOS AL FORMADOR ORIGINAL (Lo que pediste)
    $('#formadorAbc').val(formadorOriginal);
    
    // 5. Limpiamos invitados adicionales si existen
    $('.formador-row:not([data-index="0"])').remove();
    $('#wrapperCharCount, #wrapperAlcance').addClass('d-none');
    
    // 6. Limpiamos la lista de fechas
    $('#listaFechasEncuentros').empty();
    
    // 7. Resetear edit-mode para que sea CREAR no EDITAR
    $('#btnGuardarCurso').data('edit-mode', 'false').html('<i class="bi bi-check-circle me-1"></i>Crear Curso');
});
        // ─── DataTable ───────────────────────────────────────────────────────────
        if ($('#tablaCursosCargo tbody tr td[colspan]').length === 0) {
            const table = $('#tablaCursosCargo');
            const estadoColIndex = Number(table.data('estado-col-index'));
            const creadoColIndex = Number(table.data('creado-col-index'));
            const inicioColIndex = Number(table.data('inicio-col-index'));

            // Solo inicializar DataTable si hay cursos (sin row con colspan vacía)
            table.DataTable({
                language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                responsive: true,
                order: [[estadoColIndex, 'asc'], [creadoColIndex, 'desc'], [inicioColIndex, 'desc']],
                initComplete: function () {
                    const api = this.api();
                    const escapeHtml = (text) => $('<div>').text(text).html();

                    api.columns().every(function () {
                        const column = this;
                        const idx = column.index();
                        const $select = table.find(`.filtro-columna[data-column="${idx}"]`);
                        const $input = table.find(`.filtro-texto[data-column="${idx}"]`);

                        if ($select.length) {
                            const values = [];
                            column.data().unique().sort().each(function (d) {
                                const text = $('<div>').html(d).text().trim();
                                if (text && !values.includes(text)) {
                                    values.push(text);
                                }
                            });

                            values.forEach(function (val) {
                                $select.append(`<option value="${escapeHtml(val)}">${escapeHtml(val)}</option>`);
                            });

                            $select.on('change', function () {
                                const val = $(this).val();
                                column
                                    .search(val ? '^' + $.fn.dataTable.util.escapeRegex(val) + '$' : '', true, false)
                                    .draw();
                            });
                        }

                        if ($input.length) {
                            $input.on('keyup change', function () {
                                if (column.search() !== this.value) {
                                    column.search(this.value).draw();
                                }
                            });
                        }
                    });
                }
            });
        }

        // ─── Datos desde EJS ─────────────────────────────────────────────────
        const cursosExistentes = JSON.parse('<%- JSON.stringify(cursosLocales.map(c => ({ anio: c.anio, itinerario: c.itinerario, dispositivo: c.dispositivo }))) %>');

        // ─── Reglas por dispositivo ───────────────────────────────────────────────
        const REGLAS = {
            'Taller en Servicio':       { encuentros: 3, horas: 4 },
            'Taller Fuera de Servicio': { encuentros: 5, horas: 3 },
            'Seminario':                { encuentros: 3, horas: 3 },
            'Extensión CIIE':           { encuentros: 1, horas: 2 }
        };

        // ─── Helpers ─────────────────────────────────────────────────────────────
        function esTaller(dispositivo) {
            return dispositivo && dispositivo.toLowerCase().includes('taller');
        }

        function calcularPuntaje(dispositivo, encuentros) {
            if (!esTaller(dispositivo)) return '';
            const n = parseInt(encuentros) || 0;
            if (n < 3) return '';
            return n >= 8 ? 0.48 : 0.44;
        }

        function proximoItinerario(anio, dispositivo) {
            const delAnioDispositivo = cursosExistentes.filter(c => c.anio == anio && c.dispositivo === dispositivo);
            if (delAnioDispositivo.length === 0) return 1;
            return Math.max(...delAnioDispositivo.map(c => c.itinerario)) + 1;
        }

        function toDateOnlyLocal(date) {
            if (!date) return '';
            const yyyy = date.getFullYear();
            const mm = String(date.getMonth() + 1).padStart(2, '0');
            const dd = String(date.getDate()).padStart(2, '0');
            return `${yyyy}-${mm}-${dd}`;
        }

        function parseDateOnly(value) {
            if (!value) return null;
            const d = new Date(`${value}T00:00:00`);
            return Number.isNaN(d.getTime()) ? null : d;
        }

        function getFechasEncuentroInputs() {
            return $('#listaFechasEncuentros .input-fecha-encuentro');
        }

        function contarFechasEncuentro() {
            return getFechasEncuentroInputs().length;
        }

        function getFechasEncuentro() {
            return getFechasEncuentroInputs().map(function () {
                return $(this).val().trim();
            }).get();
        }

        function sugerirSiguienteFecha(fechaBase) {
            const base = parseDateOnly(fechaBase);
            if (!base) return '';
            base.setDate(base.getDate() + 14); // +14 días en lugar de +7
            return toDateOnlyLocal(base);
        }

        function actualizarCantidadEncuentrosDesdeFechas() {
            const cantidad = contarFechasEncuentro();
            $('#cantidadEncuentros').val(cantidad);
            $('#drupalPuntaje').val(calcularPuntaje($('#dispositivoSeleccionado').val(), cantidad));
        }

        function actualizarDesdePrimeraFecha() {
            const fechas = getFechasEncuentro();
            if (!fechas[0]) return;
            
            const primeraFecha = parseDateOnly(fechas[0]);
            if (!primeraFecha) return;

            // Calcular día de dictado
            const dias = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
            $('#drupalDiaDictado').val(dias[primeraFecha.getDay()]);
            
            // Recalcular itinerario
            $('#itinerario').val(proximoItinerario($('#anio').val(), $('#dispositivoSeleccionado').val()));
            
            // Completar las siguientes fechas automáticamente
            completarFechasFaltantes();
        }

        function renderFechasEncuentros(fechas = []) {
            const $lista = $('#listaFechasEncuentros').empty();

            fechas.forEach((fecha, idx) => {
                const $fila = $(
                    `<div class="d-flex align-items-center gap-2 fecha-encuentro-row" data-index="${idx + 1}">
                        <span class="badge bg-secondary" style="min-width: 34px;">E${idx + 1}</span>
                        <input type="date" class="form-control bg-dark border-secondary text-white input-fecha-encuentro" value="${fecha || ''}" required>
                        <button type="button" class="btn btn-sm btn-outline-danger btn-quitar-fecha" title="Quitar fecha" ${fechas.length === 1 ? 'disabled' : ''}>
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>`
                );
                $lista.append($fila);
            });

            if (fechas.length === 0) {
                renderFechasEncuentros(['']);
                return;
            }

            actualizarCantidadEncuentrosDesdeFechas();
        }

        function completarFechasFaltantes() {
            const fechas = getFechasEncuentro();
            for (let i = 1; i < fechas.length; i += 1) {
                if (!fechas[i]) {
                    fechas[i] = sugerirSiguienteFecha(fechas[i - 1]);
                }
            }
            renderFechasEncuentros(fechas);
        }

        function sincronizarPrimeraFechaEncuentro(fechaInicioDate) {
            const fechas = getFechasEncuentro();
            if (fechas.length === 0) {
                renderFechasEncuentros([toDateOnlyLocal(fechaInicioDate)]);
                return;
            }
            if (!fechas[0]) {
                fechas[0] = toDateOnlyLocal(fechaInicioDate);
                renderFechasEncuentros(fechas);
            }
            completarFechasFaltantes();
        }

        // Esta función ya no se usa directamente desde flatpickr
        // El cálculo de día de dictado ahora se hace en actualizarDesdePrimeraFecha()
        function actualizarDesdePrimeraFecha() {
            const fechas = getFechasEncuentro();
            if (!fechas[0]) return;
            
            const primeraFecha = parseDateOnly(fechas[0]);
            if (!primeraFecha) return;

            // Calcular día de dictado
            const dias = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
            $('#drupalDiaDictado').val(dias[primeraFecha.getDay()]);
            
            // Recalcular itinerario
            $('#itinerario').val(proximoItinerario($('#anio').val(), $('#dispositivoSeleccionado').val()));
            
            // Completar las siguientes fechas automáticamente
            completarFechasFaltantes();
        }

        // Calcula fechas de encuentros automáticamente cuando se selecciona un curso base
        function recalcularDesdeCursoBase(dispositivo) {
            const regla = REGLAS[dispositivo];
            const encuentros = regla ? regla.encuentros : '';
            const horas      = regla ? regla.horas : '';
            const fechasActuales = getFechasEncuentro();
            const base = fechasActuales[0] ? fechasActuales[0] : '';
            const fechasIniciales = [];
            if (encuentros) {
                let cursor = base;
                for (let i = 0; i < encuentros; i += 1) {
                    fechasIniciales.push(cursor || '');
                    cursor = sugerirSiguienteFecha(cursor);
                }
            }
            renderFechasEncuentros(fechasIniciales.length > 0 ? fechasIniciales : ['']);
            $('#cantidadHoras').val(horas);
            $('#drupalPuntaje').val(calcularPuntaje(dispositivo, encuentros));
            // Recalcular itinerario
            $('#itinerario').val(proximoItinerario($('#anio').val(), dispositivo));
        }

        $('#cantidadHoras').on('change input', function () {
            $('#drupalPuntaje').val(calcularPuntaje($('#dispositivoSeleccionado').val(), $('#cantidadEncuentros').val()));
        });

        $('#btnAgregarFechaEncuentro').on('click', function () {
            const fechas = getFechasEncuentro();
            const ultima = fechas.length > 0 ? fechas[fechas.length - 1] : '';
            fechas.push(sugerirSiguienteFecha(ultima));
            renderFechasEncuentros(fechas);
        });

        $(document).on('click', '.btn-quitar-fecha', function () {
            const idx = $(this).closest('.fecha-encuentro-row').index();
            const fechas = getFechasEncuentro();
            if (fechas.length <= 1) return;
            fechas.splice(idx, 1);
            renderFechasEncuentros(fechas);
        });

        $(document).on('change input', '.input-fecha-encuentro', function () {
            const idx = $(this).closest('.fecha-encuentro-row').index();
            actualizarCantidadEncuentrosDesdeFechas();
            
            // Si es la primera fecha, actualizar día de dictado, itinerario y auto-completar
            if (idx === 0) {
                actualizarDesdePrimeraFecha();
            }
        });

        renderFechasEncuentros(['']);

        $('#anio').on('change input', function () {
            const dispositivo = $('#dispositivoSeleccionado').val();
            $('#itinerario').val(proximoItinerario($(this).val(), dispositivo));
        });

        // ─── Widget formadores ────────────────────────────────────────────────────
        const MAX_FORMADORES = 3;
        const MAX_CHARS = 40;
        let agentesDelCiie   = [];
        let agentesInvitados = [];
        let nombreCompletoOriginal = ''; // para restaurar al eliminar invitados

        $('#modalAltaCurso').on('show.bs.modal', function () {
            if (agentesDelCiie.length > 0) return;
            $.get(`/agente/porCiie/<%=ciieClave%>`)
                .done(function (data) { agentesDelCiie = data || []; });
            cargarAgentesInvitados('local');
        });

        function cargarAgentesInvitados(alcance) {
            const ciieId = $('#ciieId').val();
            $.get(`/agente/porAlcance/${ciieId}`, { alcance })
                .done(function (data) { agentesInvitados = data || []; });
        }

        $(document).on('change', 'input[name="alcanceFormadores"]', function () {
            cargarAgentesInvitados($(this).val());
        });

        function abreviarNombre(nombreCompleto) {
            const partes = nombreCompleto.split(',');
            if (partes.length < 2) return nombreCompleto.trim();
            return `${partes[0].trim()}, ${partes[1].trim().charAt(0).toUpperCase()}.`;
        }

        function contarFormadores() {
            return $('#listaFormadores .formador-row').length;
        }

        function getCombinado() {
            const valores = [];
            $('#listaFormadores .input-formador').each(function () {
                const v = $(this).val().trim();
                if (v) valores.push(v);
            });
            return valores.join('; ');
        }

        function actualizarCharCount() {
            if (contarFormadores() < 2) {
                $('#wrapperCharCount').addClass('d-none');
                return;
            }
            $('#wrapperCharCount').removeClass('d-none');
            const largo = getCombinado().length;
            const pct   = Math.min((largo / MAX_CHARS) * 100, 100);
            $('#charCountLabel').text(`${largo} / ${MAX_CHARS}`);
            $('#charCountBar').css('width', `${pct}%`)
                .removeClass('bg-success bg-warning bg-danger')
                .addClass(largo > MAX_CHARS ? 'bg-danger' : largo >= MAX_CHARS * 0.8 ? 'bg-warning' : 'bg-success');
            $('#charCountWarning').toggleClass('d-none', largo <= MAX_CHARS);
        }

        function actualizarBtnAgregar() {
            $('#btnAgregarFormador').prop('disabled', contarFormadores() >= MAX_FORMADORES);
        }

        function mostrarSugerencias(agentes, $input) {
            $input = $($input);
            $input.closest('.formador-row').find('.dropdown-formadores').remove();
            if (!agentes || agentes.length === 0) return;

            const $drop = $('<div class="dropdown-formadores list-group position-absolute shadow" style="z-index:9999; min-width:250px;"></div>');
            agentes.slice(0, 6).forEach(a => {
                $drop.append(`
                    <button type="button"
                            class="list-group-item list-group-item-action bg-dark border-secondary text-white py-1 px-2"
                            style="font-size:0.85rem;"
                            data-abreviado="${a.abreviado}">
                        <span class="fw-bold">${a.abreviado}</span>
                        <small class="text-muted ms-2">${a.nombreCompleto}</small>
                    </button>
                `);
            });
            $input.parent().css('position', 'relative').append($drop);
            $drop.on('click', 'button', function () {
                $input.val($(this).data('abreviado'));
                $drop.remove();
                actualizarCharCount();
            });
            $(document).one('click', function () { $drop.remove(); });
        }

        function mostrarSugerenciasInvitado(agentes, $input) {
            $input = $($input);
            $input.closest('.formador-row').find('.dropdown-formadores').remove();
            if (!agentes || agentes.length === 0) return;

            const $drop = $('<div class="dropdown-formadores list-group position-absolute shadow" style="z-index:9999; min-width:300px;"></div>');
            agentes.slice(0, 8).forEach(a => {
                $drop.append(`
                    <button type="button"
                            class="list-group-item list-group-item-action bg-dark border-secondary text-white py-1 px-2"
                            style="font-size:0.85rem;"
                            data-abreviado="${a.abreviado}"
                            data-cargo-id="${a.cargoId}"
                            data-area="${a.area}"
                            data-ciie="${a.ciie}">
                        <span class="fw-bold">${a.abreviado}</span>
                        <small class="text-muted ms-2">${a.area} · ${a.ciie}</small>
                    </button>
                `);
            });
            $input.parent().css('position', 'relative').append($drop);
            $drop.on('click', 'button', function () {
                const $fila = $input.closest('.formador-row');
                $input.val($(this).data('abreviado'));
                $fila.attr('data-cargo-id', $(this).data('cargo-id'));
                $fila.find('.cargo-badge').remove();
                const area = $(this).data('area');
                const ciie = $(this).data('ciie');
                if (area || ciie) {
                    $fila.append(`<div class="cargo-badge text-info mt-1" style="font-size:0.7rem;"><i class="bi bi-person-badge me-1"></i>${[area, ciie].filter(Boolean).join(' · ')}</div>`);
                }
                $drop.remove();
                actualizarCharCount();
            });
            $(document).one('click', function () { $drop.remove(); });
        }

        function agregarFilaFormador() {
            const index = contarFormadores();

            if (index === 1) {
                // Guardar nombre completo original antes de abreviar
                const $principal = $('#listaFormadores .input-formador').first();
                nombreCompletoOriginal = $principal.val().trim();
                if (nombreCompletoOriginal) $principal.val(abreviarNombre(nombreCompletoOriginal));
                $('#wrapperAlcance').removeClass('d-none');
            }

            const $fila = $(`
                <div class="formador-row mb-2" data-index="${index}" data-cargo-id="">
                    <div class="d-flex gap-2 align-items-center">
                        <input type="text"
                               class="form-control form-control-sm bg-dark border-secondary text-white input-formador"
                               placeholder="Buscar por área o nombre..."
                               maxlength="40">
                        <button type="button" class="btn btn-sm btn-outline-danger btn-eliminar-formador flex-shrink-0" title="Quitar">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                </div>
            `);

            $('#listaFormadores').append($fila);
            $fila.find('.input-formador').focus();
            actualizarBtnAgregar();
            actualizarCharCount();

            $fila.find('.input-formador').on('input', function () {
                actualizarCharCount();
                const q = $(this).val().trim().toLowerCase();
                if (q.length < 2) {
                    $(this).closest('.formador-row').find('.dropdown-formadores').remove();
                    return;
                }
                const filtrados = agentesInvitados.filter(a =>
                    `${a.abreviado} ${a.nombreCompleto} ${a.area} ${a.ciie}`.toLowerCase().includes(q)
                );
                mostrarSugerenciasInvitado(filtrados, $(this));
            });
        }

        $('#listaFormadores').on('input', '#formadorAbc', function () {
            actualizarCharCount();
            const q = $(this).val().trim().toLowerCase();
            if (q.length < 2) {
                $(this).closest('.formador-row').find('.dropdown-formadores').remove();
                return;
            }
            const filtrados = agentesDelCiie.filter(a =>
                `${a.abreviado} ${a.nombreCompleto}`.toLowerCase().includes(q)
            );
            mostrarSugerencias(filtrados, $(this));
        });

        $('#btnAgregarFormador').click(agregarFilaFormador);

        $(document).on('click', '.btn-eliminar-formador', function () {
            $(this).closest('.formador-row').remove();
            actualizarBtnAgregar();
            actualizarCharCount();
            // Si volvemos a 1 formador: restaurar nombre completo y ocultar alcance
            if (contarFormadores() === 1) {
                if (nombreCompletoOriginal) {
                    $('#formadorAbc').val(nombreCompletoOriginal);
                }
                $('#wrapperAlcance').addClass('d-none');
            }
        });

        // ─── Lazy load cursos base ────────────────────────────────────────────────
        let cursosBaseCargados = false;
        let todosLosCursosBase = [];

        $('#modalSeleccionarBase').on('show.bs.modal', function () {
            if (cursosBaseCargados) return;
            cargarCursosBase();
        });

        function renderFiltros(cursos) {
            const dispositivos = [...new Set(cursos.map(c => c.dispositivo).filter(Boolean))].sort();
            const areas        = [...new Set(cursos.map(c => c.areaNombre).filter(Boolean))].sort();
            const anios        = [...new Set(cursos.map(c => c.anioReferencia).filter(Boolean))].sort((a, b) => b - a);
            $('#filtroDispositivo').empty().append('<option value="">Todos los dispositivos</option>');
            dispositivos.forEach(d => $('#filtroDispositivo').append(`<option value="${d}">${d}</option>`));
            $('#filtroArea').empty().append('<option value="">Todas las áreas</option>');
            areas.forEach(a => $('#filtroArea').append(`<option value="${a}">${a}</option>`));
            $('#filtroAnio').empty().append('<option value="">Todos los años</option>');
            anios.forEach(a => $('#filtroAnio').append(`<option value="${a}">${a}</option>`));
        }

        function renderLista(cursos) {
            const $lista = $('#listaCursosBase').empty();
            if (cursos.length === 0) {
                $lista.html('<div class="p-4 text-center text-muted">No hay cursos base que coincidan.</div>');
                return;
            }
            cursos.forEach(cb => {
                $lista.append(`
                    <button type="button"
                        class="list-group-item list-group-item-action bg-dark border-secondary item-curso-base"
                        data-id="${cb._id}"
                        data-nombre="${cb.nombre}"
                        data-dispositivo="${cb.dispositivo}"
                        data-area="${cb.areaNombre}"
                        data-anioreferencia="${cb.anioReferencia}"
                        data-idoriginal="${cb.idCursoOriginal}">
                        <div class="fw-bold text-white">${cb.nombre}</div>
                        <small class="text-muted">${cb.dispositivo} · ${cb.areaNombre} · ${cb.anioReferencia}</small>
                    </button>
                `);
            });
        }

        function filtrarYRenderizar() {
            const q           = $('#buscarCursoBase').val().toLowerCase();
            const dispositivo = $('#filtroDispositivo').val();
            const area        = $('#filtroArea').val();
            const anio        = $('#filtroAnio').val();
            const filtrados = todosLosCursosBase.filter(cb => {
                const matchTexto = !q || cb.nombre.toLowerCase().includes(q) ||
                    (cb.dispositivo || '').toLowerCase().includes(q) ||
                    (cb.areaNombre  || '').toLowerCase().includes(q);
                return matchTexto &&
                    (!dispositivo || cb.dispositivo === dispositivo) &&
                    (!area        || cb.areaNombre  === area) &&
                    (!anio        || String(cb.anioReferencia) === String(anio));
            });
            renderLista(filtrados);
        }

        function cargarCursosBase() {
            $('#estadoCargando').removeClass('d-none');
            $('#estadoError').addClass('d-none');
            $('#listaCursosBase').addClass('d-none').empty();
            $('#wrapperFiltros').addClass('d-none');
            $.get(`/cursoBase/porCiie/<%= ciieClave %>`)
                .done(function (data) {
                    cursosBaseCargados = true;
                    todosLosCursosBase = data || [];
                    $('#estadoCargando').addClass('d-none');
                    renderFiltros(todosLosCursosBase);
                    renderLista(todosLosCursosBase);
                    $('#listaCursosBase').removeClass('d-none');
                    $('#wrapperFiltros').removeClass('d-none');
                })
                .fail(function () {
                    $('#estadoCargando').addClass('d-none');
                    $('#estadoError').removeClass('d-none');
                });
        }

        $('#btnReintentar').click(cargarCursosBase);
        $('#buscarCursoBase, #filtroDispositivo, #filtroArea, #filtroAnio').on('input change', filtrarYRenderizar);

        // ─── Reset del formulario para crear nuevo curso ────────────────────────────
        function resetearFormularioAltaCurso() {
            // Limpiar campos ocultos
            $('#cursoBaseId').val('');
            $('#idCursoOriginal').val('');
            $('#nombrePropuesta').val('');
            $('#dispositivo').val('');
            $('#dispositivoSeleccionado').val('');
            $('#cursoIdParaEditar').val(''); // Importante: limpiar ID de edición
            
            // Limpiar campos visibles
            $('#anio').val(new Date().getFullYear());
            $('#itinerario').val('1');
            $('#horaEncuentro').val('18:00');
            $('#drupalFormatoDictado').val('Presencial (237)');
            $('#cupo').val('30');
            $('#cantidadEncuentros').val('');
            $('#cantidadHoras').val('');
            $('#tituloFormulario').val('');
            $('#drupalSede').val('CIIE G. de Laferrere - Monseñor López May N° 3250');
            $('#drupalOrganiza').val('DFDP');
            $('#drupalDiaDictado').val('');
            $('#drupalPuntaje').val('');
            $('#alcance').val('1');
            
            // Limpiar formadores
            
            $('#wrapperAlcance').addClass('d-none');
            nombreCompletoOriginal = '';
            
            // Limpiar fechas de encuentros
            renderFechasEncuentros(['']);
            
            // Cambiar botón guardado a modo "crear"
            $('#btnGuardarCurso').data('edit-mode', 'false').html('<i class="bi bi-check-circle me-1"></i>Crear Curso');
            
            // Limpiar resumen
            $('#resumenNombreBase').text('');
            $('#resumenDetalleBase').text('');
        }

        // ─── Paso 1 → Paso 2 ─────────────────────────────────────────────────────
        $(document).on('click', '.item-curso-base', function () {
            resetearFormularioAltaCurso();
            
            const d = $(this).data();
            $('#dispositivoSeleccionado').val(d.dispositivo || '');
            $('#cursoBaseId').val(d.id);
            $('#idCursoOriginal').val(d.idoriginal || '');
            $('#nombrePropuesta').val(d.nombre || '');
            $('#dispositivo').val(d.dispositivo || '');
            $('#resumenNombreBase').text(d.nombre);
            $('#resumenDetalleBase').text(`${d.dispositivo} · ${d.area} · ${d.anioreferencia}`);
            recalcularDesdeCursoBase(d.dispositivo);
            $('#modalSeleccionarBase').modal('hide');
            setTimeout(() => $('#modalAltaCurso').modal('show'), 400);
        });

        // ─── Volver ──────────────────────────────────────────────────────────────
        $('#btnVolver').click(function () {
            $('#modalAltaCurso').modal('hide');
            setTimeout(() => $('#modalSeleccionarBase').modal('show'), 400);
        });

        // ─── Guardar ─────────────────────────────────────────────────────────────
        $('#btnGuardarCurso').click(function () {
            const btn = $(this);
            const isEditMode = btn.data('edit-mode') === 'true';
            const cursoIdAEditar = $('#cursoIdParaEditar').val();
            const fechasEncuentros = getFechasEncuentro();
            const fechasCompletas = fechasEncuentros.filter(Boolean);

            if (fechasCompletas.length !== fechasEncuentros.length) {
                Swal.fire('Fechas incompletas', 'Completá todas las fechas de encuentros.', 'warning');
                return;
            }

            if (fechasCompletas.length === 0) {
                Swal.fire('Fechas requeridas', 'Ingresá al menos una fecha de encuentro.', 'warning');
                return;
            }

            const formadorCombinado = getCombinado();
            if (!formadorCombinado) {
                Swal.fire('Campos incompletos', 'Ingresá al menos un formador.', 'warning');
                return;
            }
            if (formadorCombinado.length > MAX_CHARS) {
                Swal.fire('Límite de caracteres', 'El nombre combinado de formadores supera los 40 caracteres.', 'warning');
                return;
            }

            const cargosInvitados = [];
            $('#listaFormadores .formador-row').each(function (i) {
                if (i === 0) return;
                const cargoId = $(this).attr('data-cargo-id');
                if (cargoId) cargosInvitados.push(cargoId);
            });

            const obligatorios = ['anio', 'itinerario', 'horaEncuentro', 'cupo',
                'cantidadEncuentros', 'cantidadHoras', 'drupalFormatoDictado',
                'drupalNivel', 'drupalSede', 'drupalOrganiza', 'alcance'];

            let valido = true;
            obligatorios.forEach(id => {
                const $campo = $('#' + id);
                if (!$campo.val()) { $campo.addClass('is-invalid'); valido = false; }
                else $campo.removeClass('is-invalid');
            });

            if (!valido) {
                Swal.fire('Campos incompletos', 'Completá todos los campos obligatorios.', 'warning');
                return;
            }

            // Agregar hora a fechas de encuentros usando ISO UTC para evitar desajustes de zona horaria
            const hora = $('#horaEncuentro').val(); // "HH:mm"
            const fechasConHora = fechasCompletas.map(fecha => {
                const fechaCompleta = new Date(`${fecha}T${hora}`);
                return fechaCompleta.toISOString();
            });

            const publicacionDrupal = {
                nivel:          $('#drupalNivel').val()          || undefined,
                formatoDictado: $('#drupalFormatoDictado').val() || undefined,
                puntaje:        $('#drupalPuntaje').val() ? Number($('#drupalPuntaje').val()) : undefined,
                sede:           $('#drupalSede').val()           || undefined,
                organiza:       $('#drupalOrganiza').val()       || undefined,
                diasHorarios:   $('#drupalDiaDictado').val()     || undefined,
                publicado:      false
            };

            const payload = {
                cursoBaseId:        $('#cursoBaseId').val(),
                cargoId:            $('#cargoId').val(),
                ciieId:             $('#ciieId').val(),
                creadoPor:          $('#creadoPor').val(),
                idCursoOriginal:    $('#idCursoOriginal').val(),
                nombrePropuesta:    $('#nombrePropuesta').val(),
                dispositivo:        $('#dispositivo').val(),
                tituloFormulario:   $('#tituloFormulario').val(),
                anio:               Number($('#anio').val()),
                itinerario:         Number($('#itinerario').val()),
                cupo:               Number($('#cupo').val()),
                alcance:            Number($('#alcance').val()),
                cantidadEncuentros: fechasConHora.length,
                cantidadHoras:      Number($('#cantidadHoras').val()),
                formadorAbc:        formadorCombinado,
                publicacionDrupal,
                cargosInvitados,
                fechasEncuentros:   fechasConHora
            };

            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Guardando...');

            $.ajax({
                url: isEditMode ? `/curso/${cursoIdAEditar}` : '/curso/alta',
                method: isEditMode ? 'PUT' : 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                success: function () {
                    const msg = isEditMode ? 'Curso actualizado' : 'Curso creado';
                    Swal.fire({ icon: 'success', title: `¡${msg}!`, showConfirmButton: false, timer: 1500 })
                        .then(() => location.reload());
                },
                error: function (xhr) {
                    btn.prop('disabled', false).html('<i class="bi bi-check-circle me-1"></i>' + (isEditMode ? 'Actualizar Curso' : 'Crear Curso'));
                    Swal.fire('Error', xhr.responseJSON?.error || 'No se pudo guardar el curso.', 'error');
                }
            });
        });

        $(document).on('input change', '.form-control, .form-select', function () {
            $(this).removeClass('is-invalid');
        });

        // ─── Editar curso pendiente ───────────────────────────────────────────────
        $(document).on('click', '.btn-editar-pendiente', function () {
            const cursoId = $(this).data('id');
            $.get(`/curso/${cursoId}`)
                .done(function (curso) {
                    // Precarga datos del curso
                    $('#cursoBaseId').val(curso.cursoBaseId?._id || '');
                    $('#idCursoOriginal').val(curso.idCursoOriginal || '');
                    $('#nombrePropuesta').val(curso.nombrePropuesta || '');
                    $('#dispositivo').val(curso.dispositivo || '');
                    $('#dispositivoSeleccionado').val(curso.dispositivo || '');
                    $('#anio').val(curso.anio || new Date().getFullYear());
                    $('#itinerario').val(curso.itinerario || 1);
                    $('#drupalFormatoDictado').val(curso.publicacionDrupal?.formatoDictado || '');
                    
                    // Extraer hora del primer encuentro si existe
                    let horaEncuentro = '18:00';
if (curso.encuentros && curso.encuentros.length > 0 && curso.encuentros[0].fecha) {
    horaEncuentro = new Date(curso.encuentros[0].fecha).toLocaleTimeString('es-AR', {
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
        timeZone: 'America/Argentina/Buenos_Aires'
    });
}
$('#horaEncuentro').val(horaEncuentro);
                    
                    $('#cupo').val(curso.cupo || 30);
                    $('#cantidadHoras').val(curso.cantidadHoras || '');
                    $('#tituloFormulario').val(curso.tituloFormulario || '');
                    $('#drupalNivel').val(curso.publicacionDrupal?.nivel || '');
                    $('#drupalSede').val(curso.publicacionDrupal?.sede || '');
                    $('#drupalOrganiza').val(curso.publicacionDrupal?.organiza || '');
                    $('#drupalDiaDictado').val(curso.publicacionDrupal?.diasHorarios || 'Lunes');
                    $('#drupalPuntaje').val(curso.publicacionDrupal?.puntaje || '');
                    $('#alcance').val(curso.alcance || 1);

                    // Cargar fechas de encuentros
                    let fechas = [];
                    if (curso.encuentros && curso.encuentros.length > 0) {
                        fechas = curso.encuentros.map(e => {
                            if (e.fecha) {
                                const dateStr = e.fecha instanceof Date ? e.fecha.toISOString().split('T')[0] : e.fecha.split('T')[0];
                                return dateStr;
                            }
                            return '';
                        });
                    }
                    renderFechasEncuentros(fechas.length > 0 ? fechas : ['']);

                    // Resumen
                    $('#resumenNombreBase').text(curso.nombrePropuesta || 'Curso sin nombre');
                    $('#resumenDetalleBase').text(`${curso.dispositivo || ''} · ${curso.anio || ''}`);

                    // Cargar formadores - limpiar formadores invitados
                    $('#listaFormadores').empty();
                    $('#listaFormadores').append(`
                        <div class="formador-row mb-1" data-index="0" data-cargo-id="">
                            <input type="text"
                                   class="form-control form-control-sm bg-dark border-secondary text-white input-formador"
                                   id="formadorAbc" name="formadorAbc"
                                   maxlength="40" placeholder="Apellido, Nombre"
                                   value="${curso.formadorAbc || ''}" required>
                        </div>
                    `);
                    $('#wrapperAlcance').addClass('d-none'); // Ocultar alcance en edición pendiente
                    nombreCompletoOriginal = curso.formadorAbc || '';
                    
                    // Guardar ID del documento para poder editar
                    $('#cursoIdParaEditar').val(cursoId);

                    // Cambiar texto del botón a "Actualizar"
                    $('#btnGuardarCurso').data('edit-mode', 'true').html('<i class="bi bi-check-circle me-1"></i>Actualizar Curso');

                    $('#modalAltaCurso').modal('show');
                })
                .fail(function () {
                    Swal.fire('Error', 'No se pudo cargar el curso.', 'error');
                });
        });

        // ─── Eliminar curso pendiente ─────────────────────────────────────────────
        $(document).on('click', '.btn-eliminar-pendiente', function () {
            const cursoId = $(this).data('id');
            const $row = $(this).closest('tr');
            const nombreCurso = $row.find('td:nth-child(3)').text().trim();

            Swal.fire({
                title: '¿Eliminar curso?',
                html: `<small class="text-muted">Se eliminará el curso "${nombreCurso}" y todos sus encuentros relacionados.</small>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: `/curso/${cursoId}`,
                        method: 'DELETE',
                        success: function () {
                            Swal.fire({
                                icon: 'success',
                                title: 'Curso eliminado',
                                showConfirmButton: false,
                                timer: 1500
                            }).then(() => location.reload());
                        },
                        error: function (xhr) {
                            const mensaje = xhr.responseJSON?.error || 'No se pudo eliminar el curso.';
                            Swal.fire('Error', mensaje, 'error');
                        }
                    });
                }
            });
        });

        // ─── Vincular curso pendiente con sitio oficial desde cuenta institucional ───────
        async function publicarCursoDirectamente(cursoClave, ciieClave) {
            try {
                const response = await fetch('/ciie/cursos/nuevo/publicar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cursoClave, ciieClave })
                });
                const result = await response.json();

                if (!response.ok || !result.success) {
                    throw new Error(result.error || 'No se pudo publicar el curso en el sitio oficial.');
                }

                Swal.fire({
                    icon: 'success',
                    title: 'Curso publicado',
                    text: 'El curso se vinculó directamente con el sitio oficial.',
                    showConfirmButton: false,
                    timer: 1800
                }).then(() => location.reload());
            } catch (error) {
                Swal.fire('Error', error.message, 'error');
            }
        }

        $(document).on('click', '.btn-vincular-oficial', function () {
            const cursoClave = $(this).data('curso-clave');
            const ciieClave = '<%=ciieClave%>';
            alert(cursoClave)
            if (!cursoClave) return;
            publicarCursoDirectamente(cursoClave, ciieClave);
        });

        // ─── Auto-abrir modal de edición si viene con parámetro editar ─────────────────────
        const urlParams = new URLSearchParams(window.location.search);
        const cursoIdParaEditar = urlParams.get('editar');
        if (cursoIdParaEditar) {
            // Simular clic en el botón de editar del curso
            $(`.btn-editar-pendiente[data-id="${cursoIdParaEditar}"]`).trigger('click');
        }

    }); // fin document.ready

    function copyToClipboard(text) {
        navigator.clipboard.writeText(text).then(() => {
            alert('Enlace de inscripción copiado al portapapeles');
        });
    }
    </script>
</body>
</html>
