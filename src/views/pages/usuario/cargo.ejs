<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <link rel="icon" type="image/png" href="/img/LogoSicaa.png">
    <%- include('../../partials/head') %>
    <title> SICA - Inscriptos </title>
</head>
<body>
    <%- include('../../partials/navbar') %>
    
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2>💼 Mis Cargos <small>(<%= cargos.length  %>)</small></h2>
                <p class="text-muted">Seleccioná el cargo con el que vas a operar hoy</p>
            </div>
            <a href="#" class="btn btn-success disabled">
                ➕ Solicitar Nueva Asignación
            </a>
        </div>

        <div class="table-responsive shadow-sm rounded">
            <table id="tablaCargos" class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>CIIE / Región</th>
                        <th>Cargo</th>
                        <th>Área</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (cargos && cargos.length > 0) { %>
                        <% cargos.forEach(cargo => { %>
                            <tr>
                                <td>
                                    <strong><%= cargo.ciieId.nombre %></strong>
                                    <br>
                                    <small class="text-muted">Región <%= cargo.ciieId.region %></small>
                                </td>
                                <td>
                                    <%= cargo.rolId.nombre %>
                                </td>
                                <td>
                                    <%= cargo.areaId?.nombre || '' %>
                                    <br>
                                    <small class="text-muted"><%= cargo.areaId?.nivel %></small>
                                </td>
                                <td>
                                    <% if (cargo.ocupante && cargo.ocupante.estado === 'Activo') { %>
                                        <span class="badge bg-success">Activo</span>
                                    <% } else if (cargo.ocupante && cargo.ocupante.estado === 'Licencia') { %>
                                        <span class="badge bg-warning text-dark">En Licencia</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary">Sin ocupante</span>
                                    <% } %>
                                </td>
                                <td class="text-center">
                                    <% if (cargo.ocupante && cargo.ocupante.estado === 'Activo') { %>
                                        <a href="/curso/<%= cargo.clave %>/<%= cargo.ciieId?.clave %>/" class="btn btn-primary">
                                            Acceder ➔
                                        </a>
                                    <% } else { %>
                                        <button class="btn btn-secondary btn-sm" disabled>Sin ocupante</button>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <p class="mb-3">No tenés cargos asignados en este momento.</p>
                                <a href="/usuario/solicitar-cargo" class="btn btn-outline-primary">
                                    Hacé clic acá para solicitar tu primer cargo
                                </a>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <%- include('../../partials/scripts') %>

    <script>
        $(document).ready(function() {
            $('#tablaCargos').DataTable({
                language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                responsive: true,
                paging: false
            });
        });
    </script>
</body>
</html>