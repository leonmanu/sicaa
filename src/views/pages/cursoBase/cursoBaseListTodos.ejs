<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">

<head>
    <%- include('../../partials/head') %>
    <title>SICAA - Cursos Base</title>
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
</head>

<body>
    <%- include('../../partials/navbar') %>
    <%- include('../../partials/msj') %>

    <div class="container">
        <div class="row mb-4">
            <div class="col-12">
                <h2 class="h3 mb-3 d-flex align-items-start">
                    <i class="bi bi-archive-fill text-warning me-3 mt-1"></i>
                    <span class="lh-sm">Cursos Base</span>
                </h2>

                <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
                    <span class="badge bg-primary py-2 px-3">
                        <i class="bi bi-collection-fill me-1"></i>
                        <%= cursosBase.length %> Cursos Base
                    </span>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap align-items-center justify-content-end gap-3 mb-4 p-3 bg-dark border border-secondary rounded-3 shadow-sm">
            <button id="btnSincronizarAbc" class="btn btn-warning fw-bold px-3">
                <i class="bi bi-cloud-download-fill me-2"></i>Sincronizar con ABC
            </button>
        </div>

        <!-- Sección de nuevos detectados -->
        <div id="seccionPendientes" class="card border-warning bg-dark mb-4 d-none">
            <div class="card-header bg-warning text-dark fw-bold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-exclamation-triangle-fill me-2"></i>Nuevos cursos base detectados en ABC</span>
                <button id="btnVincularAhora" class="btn btn-sm btn-dark">Agregar a Base Local</button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-sm mb-0 small">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Dispositivo</th>
                                <th>Área</th>
                                <th>Año</th>
                            </tr>
                        </thead>
                        <tbody id="listaPendientes"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Tabla principal -->
        <div class="card shadow-sm border-0 bg-dark text-white">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="tablaCursosBase" class="table table-dark table-hover align-middle mb-0">
                        <thead class="bg-black text-muted small text-uppercase">
                            <tr>
                                <th>Nombre</th>
                                <th>Dispositivo</th>
                                <th>Área</th>
                                <th>Año</th>
                                <th>Estado ABC</th>
                                <th class="text-center pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (cursosBase && cursosBase.length > 0) { %>
                                <% cursosBase.forEach(cb => { %>
                                    <tr>
                                        <td class="fw-bold"><%= cb.nombre %></td>
                                        <td><small class="text-muted"><%= cb.dispositivo %></small></td>
                                        <td><%= cb.areaNombre %></td>
                                        <td><%= cb.anioReferencia %></td>
                                        <td>
                                            <span class="badge <%= cb.estadoAbc === 'S' ? 'bg-success' : 'bg-secondary' %>">
                                                <%= cb.estadoAbc === 'S' ? 'Disponible' : 'No disponible' %>
                                            </span>
                                        </td>
                                        <td class="text-center pe-4">
                                            <button class="btn btn-sm btn-outline-light btn-ver-detalle"
                                                data-id="<%= cb._id %>"
                                                data-nombre="<%= cb.nombre %>"
                                                data-dispositivo="<%= cb.dispositivo %>"
                                                data-area="<%= cb.areaNombre %>"
                                                data-anio="<%= cb.anioReferencia %>"
                                                data-estado="<%= cb.estadoAbc %>"
                                                data-idoriginal="<%= cb.idCursoOriginal %>"
                                                data-activo="<%= cb.activo %>">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL: Detalle CursoBase -->
    <div class="modal fade" id="modalDetalle" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-warning fw-bold">
                        <i class="bi bi-archive-fill me-2"></i>Detalle del Curso Base
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted small">ID Original</dt>
                        <dd class="col-sm-8 fw-bold" id="detIdOriginal"></dd>

                        <dt class="col-sm-4 text-muted small">Nombre</dt>
                        <dd class="col-sm-8" id="detNombre"></dd>

                        <dt class="col-sm-4 text-muted small">Dispositivo</dt>
                        <dd class="col-sm-8" id="detDispositivo"></dd>

                        <dt class="col-sm-4 text-muted small">Área</dt>
                        <dd class="col-sm-8" id="detArea"></dd>

                        <dt class="col-sm-4 text-muted small">Año</dt>
                        <dd class="col-sm-8" id="detAnio"></dd>

                        <dt class="col-sm-4 text-muted small">Estado ABC</dt>
                        <dd class="col-sm-8" id="detEstado"></dd>

                        <dt class="col-sm-4 text-muted small">Activo</dt>
                        <dd class="col-sm-8" id="detActivo"></dd>
                    </dl>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <%- include('../../partials/scripts') %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let temporalNuevos = [];

        $(document).ready(function () {
            $('#tablaCursosBase').DataTable({
                language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                pageLength: 25,
                order: [[3, 'desc']]
            });

            // ===== DETALLE =====

            $(document).on('click', '.btn-ver-detalle', function () {
                const d = $(this).data();
                $('#detIdOriginal').text(d.idoriginal);
                $('#detNombre').text(d.nombre);
                $('#detDispositivo').text(d.dispositivo);
                $('#detArea').text(d.area);
                $('#detAnio').text(d.anio);
                $('#detEstado').html(d.estado === 'S' 
                    ? '<span class="badge bg-success">Disponible</span>' 
                    : '<span class="badge bg-secondary">No disponible</span>');
                $('#detActivo').html(d.activo === true || d.activo === 'true'
                    ? '<span class="badge bg-success">Sí</span>'
                    : '<span class="badge bg-danger">No</span>');
                $('#modalDetalle').modal('show');
            });

            // ===== SINCRONIZAR CON ABC =====

            $('#btnSincronizarAbc').click(function () {
                const btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Consultando...');

                $.get('/cursoBase/sincronizar', function (res) {
                    if (res.nuevos && res.nuevos.length > 0) {
                        temporalNuevos = res.nuevos;
                        $('#listaPendientes').empty();
                        res.nuevos.forEach(n => {
                            $('#listaPendientes').append(`
                                <tr>
                                    <td>${n[0]}</td>
                                    <td>${n[1]}</td>
                                    <td>${n[4]}</td>
                                    <td>${n[5]}</td>
                                    <td>${n[3]}</td>
                                </tr>
                            `);
                        });
                        $('#seccionPendientes').removeClass('d-none');
                    } else {
                        Swal.fire({
                            icon: 'info',
                            title: 'Sin novedades',
                            text: 'No se encontraron nuevos cursos base en ABC',
                            confirmButtonColor: '#0d6efd'
                        });
                    }
                }).fail(function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'No se pudo consultar el ABC. Intente nuevamente.',
                        confirmButtonColor: '#dc3545'
                    });
                }).always(() => {
                    btn.prop('disabled', false).html('<i class="bi bi-cloud-download-fill me-2"></i>Sincronizar con ABC');
                });
            });

            // ===== VINCULAR =====

            $('#btnVincularAhora').click(function () {
                const cantidad = temporalNuevos.length;

                Swal.fire({
                    title: '¿Agregar cursos base?',
                    html: `<p class="mb-2">Se agregarán <strong>${cantidad} cursos base</strong> a la base local</p>`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, agregar',
                    cancelButtonText: 'Cancelar',
                    confirmButtonColor: '#ffc107',
                    cancelButtonColor: '#6c757d'
                }).then((result) => {
                    if (result.isConfirmed) {
                        iniciarVinculacion();
                    }
                });
            });
        });

        function iniciarVinculacion() {
            Swal.fire({
                title: 'Guardando cursos base',
                html: `
                    <div class="mb-3">
                        <div class="spinner-border text-warning" role="status"></div>
                    </div>
                    <p class="text-muted small">Este proceso puede tardar unos segundos</p>
                `,
                allowOutsideClick: false,
                allowEscapeKey: false,
                showConfirmButton: false
            });

            $.post('/cursoBase/guardar', { data: temporalNuevos })
                .done(function (res) {
                    Swal.fire({
                        icon: 'success',
                        title: '¡Listo!',
                        html: `<p>Se agregaron <strong>${res.count || temporalNuevos.length}</strong> cursos base</p>`,
                        confirmButtonColor: '#198754',
                        confirmButtonText: 'Ver lista actualizada'
                    }).then(() => location.reload());
                })
                .fail(function (xhr) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: xhr.responseJSON?.error || 'Ocurrió un error. Intente nuevamente.',
                        confirmButtonColor: '#dc3545'
                    });
                });
        }
    </script>
</body>

</html>
