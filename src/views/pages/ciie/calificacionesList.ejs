<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <%- include('../../partials/head') %>
    <title>SICAA - Envio de Calificaciones</title>
</head>
<body>
    <%- include('../../partials/navbar') %>
    <%- include('../../partials/msj') %>

    <div class="container py-5">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <h2 class="fw-bold mb-1">
                    <i class="bi bi-award me-2 text-info"></i>Calificaciones Pendientes de Envío
                </h2>
                <p class="text-muted mb-0">Cursos vinculados con calificaciones aún no enviadas al ABC.</p>
            </div>
            <a href="/ciie/cursos" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver a cursos
            </a>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-3 justify-content-end">
            <button id="btnSeleccionarTodo" class="btn btn-outline-light btn-sm">
                <i class="bi bi-check2-square me-1"></i>Seleccionar todos
            </button>
            <button id="btnEnviarSeleccionados" class="btn btn-info btn-sm text-dark fw-bold">
                <i class="bi bi-cloud-upload me-1"></i>Enviar seleccionados
            </button>
        </div>

        <div class="card bg-dark border-secondary shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="tablaCalificacionesPendientes" class="table table-dark table-hover align-middle mb-0">
                        <thead class="small text-uppercase text-muted">
                            <tr>
                                <th class="text-center" style="width: 52px;">
                                    <input id="checkAllCursos" type="checkbox" class="form-check-input" aria-label="Seleccionar todos">
                                </th>
                                <th>ID</th>
                                <th>Curso</th>
                                <th>Cargo</th>
                                <th>Dispositivo</th>
                                <th>Año/Coh.</th>
                                <th>Inicio</th>
                                <th>Estado</th>
                                <th class="text-end pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (cursosPendientes && cursosPendientes.length > 0) { %>
                                <% cursosPendientes.forEach(curso => { %>
                                    <tr>
                                        <td class="text-center">
                                            <input
                                                type="checkbox"
                                                class="form-check-input check-curso"
                                                data-curso-id="<%= curso._id %>"
                                                aria-label="Seleccionar curso">
                                        </td>

                                        <!-- ID oficial -->
                                        <td>
                                            <span class="text-muted small"><%= curso.idOfertaOficial || '-' %></span>
                                        </td>

                                        <!-- Nombre + formador -->
                                        <td>
                                            <div class="fw-semibold"><%= curso.nombrePropuesta || 'Sin nombre' %></div>
                                            <small class="text-muted">* <%= curso.formadorAbc || 'Sin formador' %></small>
                                        </td>

                                        <!-- Área del cargo -->
                                        <td>
                                            <small><%= curso.cargoId?.areaId?.nombre || 'Área sin definir' %></small>
                                        </td>

                                        <!-- Dispositivo -->
                                        <td>
                                            <small class="text-muted"><%= curso.dispositivo || '-' %></small>
                                        </td>

                                        <!-- Año / Cohorte -->
                                        <td>
                                            <span class="text-info fw-bold"><%= curso.anio || '-' %></span>
                                            <small class="text-muted">C<%= curso.cohorte ?? 0 %></small>
                                        </td>

                                        <!-- Fecha de inicio dd/mm -->
                                        <td>
                                            <small><%=
                                                curso.fechaInicioCurso
                                                    ? new Date(curso.fechaInicioCurso).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit' })
                                                    : '-'
                                            %></small>
                                        </td>

                                        <!-- Estado calificaciones -->
                                        <td>
                                            <% const estadoCal = curso.calificaciones?.estado || 'sin_cargar'; %>
                                            <% if (estadoCal === 'enviado') { %>
                                                <span class="badge bg-success">Enviado</span>
                                            <% } else if (estadoCal === 'pendiente_envio') { %>
                                                <span class="badge bg-info text-dark">Pendiente</span>
                                            <% } else { %>
                                                <span class="badge bg-warning text-dark">Sin cargar</span>
                                            <% } %>
                                        </td>

                                        <!-- Acciones -->
                                        <td class="text-end pe-4">
                                            <div class="btn-group" role="group">
                                                <a href="calificaciones/<%= curso._id %>"
                                                   class="btn btn-outline-info btn-sm"
                                                   title="Ver detalle y enviar">
                                                    <i class="bi bi-pencil-square me-1"></i>Detalle
                                                </a>
                                                <button
                                                    class="btn btn-outline-secondary btn-sm btn-enviar-uno"
                                                    data-curso-id="<%= curso._id %>"
                                                    title="Enviar solo este curso">
                                                    <i class="bi bi-cloud-upload"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="9" class="text-center py-5 text-muted">
                                        No hay cursos pendientes de envío de calificaciones.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <%- include('../../partials/scripts') %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function getCursosSeleccionados() {
            return $('.check-curso:checked').map(function () {
                return $(this).data('curso-id');
            }).get();
        }

        async function enviarCursos(cursoIds) {
            try {
                const response = await fetch('/ciie/calificaciones/enviar-lote', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cursoIds })
                });

                const result = await response.json();
                if (!result.success) throw new Error(result.error || 'No se pudo procesar el envío.');

                const ok     = result.resultado?.ok ?? 0;
                const error  = result.resultado?.error ?? 0;
                const resumenErrores = (result.resultado?.detalles || [])
                    .filter(d => !d.success)
                    .slice(0, 5)
                    .map(d => `${d.cursoId}: ${d.error}`)
                    .join('<br>');

                await Swal.fire({
                    icon: error > 0 ? 'warning' : 'success',
                    title: 'Proceso finalizado',
                    html: `Enviados: <b>${ok}</b><br>Con error: <b>${error}</b>${resumenErrores ? `<br><br><small>${resumenErrores}</small>` : ''}`
                });

                location.reload();
            } catch (error) {
                Swal.fire('Error', error.message, 'error');
            }
        }

        $(document).ready(function () {
            $('#tablaCalificacionesPendientes').DataTable({
                language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                pageLength: 10,
                order: [[5, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [0, 8] }
                ]
            });

            // ─── Check all ───────────────────────────────────────────────────
            $('#checkAllCursos').on('change', function () {
                $('.check-curso').prop('checked', this.checked);
            });

            $('#btnSeleccionarTodo').on('click', function () {
                const total   = $('.check-curso').length;
                const marcados = $('.check-curso:checked').length;
                const nuevoEstado = !(total > 0 && total === marcados);
                $('.check-curso').prop('checked', nuevoEstado);
                $('#checkAllCursos').prop('checked', nuevoEstado);
            });

            // ─── Enviar seleccionados ─────────────────────────────────────────
            $('#btnEnviarSeleccionados').on('click', async function () {
                const cursoIds = getCursosSeleccionados();
                if (!cursoIds.length) {
                    Swal.fire('Atención', 'Seleccioná al menos un curso.', 'warning');
                    return;
                }
                const confirm = await Swal.fire({
                    icon: 'question',
                    title: 'Enviar calificaciones',
                    text: `Se procesarán ${cursoIds.length} curso(s) seleccionado(s).`,
                    showCancelButton: true,
                    confirmButtonText: 'Sí, enviar',
                    cancelButtonText: 'Cancelar'
                });
                if (!confirm.isConfirmed) return;
                await enviarCursos(cursoIds);
            });

            // ─── Enviar uno solo ──────────────────────────────────────────────
            $(document).on('click', '.btn-enviar-uno', async function () {
                const cursoId = $(this).data('curso-id');
                const confirm = await Swal.fire({
                    icon: 'question',
                    title: '¿Enviar este curso?',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, enviar',
                    cancelButtonText: 'Cancelar'
                });
                if (!confirm.isConfirmed) return;
                await enviarCursos([cursoId]);
            });
        });
    </script>
</body>
</html>
