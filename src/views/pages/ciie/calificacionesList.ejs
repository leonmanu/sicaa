<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <%- include('../../partials/head') %>
    <title>SICAA - Envio de Calificaciones</title>
</head>
<body>
    <%- include('../../partials/navbar') %>
    <%- include('../../partials/msj') %>

    <div class="container py-5">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <h2 class="fw-bold mb-1">
                    <i class="bi bi-award me-2 text-info"></i>Cursos para Certificados y Actas
                </h2>
                <p class="text-muted mb-0">Listado completo de cursos vinculados para revisar, enviar y generar documentos.</p>
            </div>
            <a href="/ciie/cursos" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver a cursos
            </a>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-3 justify-content-end">
            <a href="/ciie/certificados/aprobados-itinerario" class="btn btn-outline-warning btn-sm">
                <i class="bi bi-table me-1"></i>Planilla aprobados por itinerario
            </a>
            <button id="btnSeleccionarTodo" class="btn btn-outline-light btn-sm">
                <i class="bi bi-check2-square me-1"></i>Seleccionar todos
            </button>
            <button id="btnEnviarSeleccionados" class="btn btn-info btn-sm text-dark fw-bold">
                <i class="bi bi-cloud-upload me-1"></i>Enviar seleccionados
            </button>
            <button id="btnVerCertificadosSeleccionados" class="btn btn-outline-success btn-sm">
                <i class="bi bi-patch-check me-1"></i>Ver certificados
            </button>
            <button id="btnVerActasSeleccionadas" class="btn btn-outline-warning btn-sm">
                <i class="bi bi-journal-text me-1"></i>Ver actas
            </button>
            <button id="btnVerDocumentosSeleccionados" class="btn btn-outline-light btn-sm">
                <i class="bi bi-collection me-1"></i>Ver ambos
            </button>
        </div>

        <div class="card bg-dark border-secondary shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="tablaCalificacionesPendientes" class="table table-dark table-hover align-middle mb-0">
                        <thead class="small text-uppercase text-muted">
                            <tr>
                                <th class="text-center" style="width: 52px;">
                                    <input id="checkAllCursos" type="checkbox" class="form-check-input" aria-label="Seleccionar todos">
                                </th>
                                <th>ID</th>
                                <th>Curso</th>
                                <th>Cargo</th>
                                <th>Dispositivo</th>
                                <th>Año/Coh.</th>
                                <th>Inicio</th>
                                <th>Sin Calificar</th>
                                <th>Estado</th>
                                <th class="text-end pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (cursosPendientes && cursosPendientes.length > 0) { %>
                                <% cursosPendientes.forEach(curso => { %>
                                    <tr>
                                        <td class="text-center">
                                            <input
                                                type="checkbox"
                                                class="form-check-input check-curso"
                                                data-curso-id="<%= curso.idOfertaOficial %>"
                                                data-area="<%= curso.cargoId?.areaId?.nombre || 'Sin area' %>"
                                                aria-label="Seleccionar curso">
                                        </td>

                                        <!-- ID oficial -->
                                        <td>
                                            <span class="text-muted small"><%= curso.idOfertaOficial || '-' %></span>
                                        </td>

                                        <!-- Nombre + formador -->
                                        <td>
                                            <div class="fw-semibold"><%= curso.nombrePropuesta || 'Sin nombre' %></div>
                                            <small class="text-muted">* <%= curso.formadorAbc || 'Sin formador' %></small>
                                        </td>

                                        <!-- Área del cargo -->
                                        <td>
                                            <small><%= curso.cargoId?.areaId?.nombre || 'Área sin definir' %></small>
                                        </td>

                                        <!-- Dispositivo -->
                                        <td>
                                            <small class="text-muted"><%= curso.dispositivo || '-' %></small>
                                        </td>

                                        <!-- Año / Cohorte -->
                                        <td>
                                            <span class="text-info fw-bold"><%= curso.anio || '-' %></span>
                                            <small class="text-muted">C<%= curso.cohorte ?? 0 %></small>
                                        </td>

                                        <!-- Fecha de inicio dd/mm -->
                                        <td>
                                            <small><%=
                                                curso.fechaInicioCurso
                                                    ? new Date(curso.fechaInicioCurso).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit' })
                                                    : '-'
                                            %></small>
                                        </td>

                                        <td>
                                            <% const sinCalificar = curso.cantidadSinCalificar ?? 0; %>
                                            <% if (sinCalificar > 0) { %>
                                                <span class="badge bg-danger"><%= sinCalificar %></span>
                                            <% } else { %>
                                                <span class="badge bg-success">0</span>
                                            <% } %>
                                        </td>

                                        <!-- Estado calificaciones -->
                                        <td>
                                            <% const estadoCal = curso.calificaciones?.estado || 'sin_cargar'; %>
                                            <% if (estadoCal === 'enviado') { %>
                                                <span class="badge bg-success">Enviado</span>
                                            <% } else if (estadoCal === 'pendiente_envio') { %>
                                                <span class="badge bg-info text-dark">Pendiente</span>
                                            <% } else { %>
                                                <span class="badge bg-warning text-dark">Sin cargar</span>
                                            <% } %>
                                        </td>

                                        <!-- Acciones -->
                                        <td class="text-end pe-4">
                                            <div class="btn-group" role="group">
                                                <a href="calificaciones/<%= curso.idOfertaOficial %>"
                                                   class="btn btn-outline-info btn-sm"
                                                   title="Ver detalle y enviar">
                                                    <i class="bi bi-pencil-square me-1"></i>Detalle
                                                </a>
                                                <button
                                                    class="btn btn-outline-secondary btn-sm btn-enviar-uno"
                                                    data-curso-id="<%= curso.idOfertaOficial %>"
                                                    data-area="<%= curso.cargoId?.areaId?.nombre || 'Sin area' %>"
                                                    title="Enviar solo este curso">
                                                    <i class="bi bi-cloud-upload"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="10" class="text-center py-5 text-muted">
                                        No hay cursos vinculados para mostrar.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <%- include('../../partials/scripts') %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function getCursosSeleccionados() {
            return $('.check-curso:checked').map(function () {
                return $(this).data('curso-id');
            }).get();
        }

        function getAreaByCursoId(cursoId) {
            const check = $(`.check-curso[data-curso-id="${cursoId}"]`).first();
            if (check.length) return check.data('area') || 'Sin area';

            const btn = $(`.btn-enviar-uno[data-curso-id="${cursoId}"]`).first();
            return btn.length ? (btn.data('area') || 'Sin area') : 'Sin area';
        }

        async function enviarCursosConProgreso(cursoIds) {
            const resumen = { ok: 0, error: 0, detalles: [] };

            Swal.fire({
                title: 'Enviando calificaciones',
                html: `Preparando envío...<br><small>0/${cursoIds.length}</small>`,
                allowOutsideClick: false,
                allowEscapeKey: false,
                showConfirmButton: false,
                didOpen: () => Swal.showLoading()
            });

            for (let i = 0; i < cursoIds.length; i += 1) {
                const idOfertaOficial = cursoIds[i];
                const areaActual = getAreaByCursoId(idOfertaOficial);
                Swal.update({
                    html: `Procesando ${i + 1}/${cursoIds.length}<br><small>Oferta: ${idOfertaOficial}</small><br><small>Área: ${areaActual}</small>`
                });

                try {
                    const response = await fetch(`/ciie/calificaciones/${idOfertaOficial}/enviar-directo`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const result = await response.json();
                    if (!result.success) throw new Error(result.error || 'No se pudo enviar el curso.');

                    resumen.ok += 1;
                    resumen.detalles.push({
                        success: true,
                        idOfertaOficial,
                        area: result.resultado?.curso?.cargoId?.areaId?.nombre || 'Sin area'
                    });
                } catch (error) {
                    resumen.error += 1;
                    resumen.detalles.push({
                        success: false,
                        idOfertaOficial,
                        error: error.message,
                        area: getAreaByCursoId(idOfertaOficial)
                    });
                }
            }

            Swal.close();

            const fallosPorArea = resumen.detalles
                .filter(d => !d.success)
                .reduce((acc, d) => {
                    const area = d.area || 'Sin area';
                    acc[area] = acc[area] || [];
                    acc[area].push(`${d.idOfertaOficial}: ${d.error}`);
                    return acc;
                }, {});

            const detalleFallos = Object.keys(fallosPorArea).length
                ? Object.entries(fallosPorArea)
                    .map(([area, fallos]) => `<b>${area}</b><br><small>${fallos.join('<br>')}</small>`)
                    .join('<br><br>')
                : '';

            await Swal.fire({
                icon: resumen.error > 0 ? 'warning' : 'success',
                title: 'Proceso finalizado',
                html: `Enviados: <b>${resumen.ok}</b><br>Con error: <b>${resumen.error}</b>${detalleFallos ? `<br><br>${detalleFallos}` : ''}`
            });

            location.reload();
        }

        function abrirDocumentosSeleccionados(tipo) {
            const cursoIds = getCursosSeleccionados();
            if (!cursoIds.length) {
                Swal.fire('Atención', 'Seleccioná al menos un curso.', 'warning');
                return;
            }
            const query = new URLSearchParams({
                tipo,
                cursoIds: cursoIds.join(',')
            });
            window.location.href = `/ciie/calificaciones/documentos?${query.toString()}`;
        }

        $(document).ready(function () {
            $('#tablaCalificacionesPendientes').DataTable({
                language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                pageLength: 10,
                order: [[5, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [0, 9] }
                ]
            });

            // ─── Check all ───────────────────────────────────────────────────
            $('#checkAllCursos').on('change', function () {
                $('.check-curso').prop('checked', this.checked);
            });

            $('#btnSeleccionarTodo').on('click', function () {
                const total   = $('.check-curso').length;
                const marcados = $('.check-curso:checked').length;
                const nuevoEstado = !(total > 0 && total === marcados);
                $('.check-curso').prop('checked', nuevoEstado);
                $('#checkAllCursos').prop('checked', nuevoEstado);
            });

            // ─── Enviar seleccionados ─────────────────────────────────────────
            $('#btnEnviarSeleccionados').on('click', async function () {
                const cursoIds = getCursosSeleccionados();
                if (!cursoIds.length) {
                    Swal.fire('Atención', 'Seleccioná al menos un curso.', 'warning');
                    return;
                }
                const confirm = await Swal.fire({
                    icon: 'question',
                    title: 'Enviar calificaciones',
                    text: `Se procesarán ${cursoIds.length} curso(s) seleccionado(s).`,
                    showCancelButton: true,
                    confirmButtonText: 'Sí, enviar',
                    cancelButtonText: 'Cancelar'
                });
                if (!confirm.isConfirmed) return;
                await enviarCursosConProgreso(cursoIds);
            });

            $('#btnVerCertificadosSeleccionados').on('click', function () {
                abrirDocumentosSeleccionados('certificados');
            });

            $('#btnVerActasSeleccionadas').on('click', function () {
                abrirDocumentosSeleccionados('acta');
            });

            $('#btnVerDocumentosSeleccionados').on('click', function () {
                abrirDocumentosSeleccionados('ambos');
            });

            // ─── Enviar uno solo ──────────────────────────────────────────────
            $(document).on('click', '.btn-enviar-uno', async function () {
                const cursoId = $(this).data('curso-id');
                const confirm = await Swal.fire({
                    icon: 'question',
                    title: '¿Enviar este curso?',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, enviar',
                    cancelButtonText: 'Cancelar'
                });
                if (!confirm.isConfirmed) return;
                await enviarCursosConProgreso([cursoId]);
            });
        });
    </script>
</body>
</html>
