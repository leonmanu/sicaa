<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <%- include('../../partials/head') %>
    <title>SICAA - Actas</title>
    <style>
        body { background: #eef1f5 !important; }
        .acta-sheet {
            background: #fff;
            border: 1px solid #d7deea;
            border-radius: 16px;
            box-shadow: 0 10px 28px rgba(18, 36, 64, 0.08);
            overflow: hidden;
        }
        .acta-head {
            background: linear-gradient(120deg, #ef7c1f, #f0a53a);
            color: #fff;
            padding: 20px 24px;
        }
        .acta-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.95rem;
        }
        .acta-table th, .acta-table td {
            border: 1px solid #d9e1ed;
            padding: 8px 10px;
            color: #243a57;
        }
        .acta-table th {
            background: #f4f7fb;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.78rem;
        }
        @media print {
            body { background: #fff !important; }
            .navbar, .btn, .badge, .no-print { display: none !important; }
            .container { max-width: none !important; width: 100% !important; padding: 0 !important; }
            .acta-sheet { box-shadow: none !important; border: 0 !important; margin-bottom: 10mm; }
            .acta-row { break-inside: avoid; page-break-inside: avoid; }
        }
    </style>
</head>
<body>
    <%- include('../../partials/navbar') %>
    <%- include('../../partials/msj') %>

    <div class="container py-5">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <h2 class="fw-bold mb-1">
                    <i class="bi bi-journal-text me-2 text-warning"></i>Actas
                </h2>
                <p class="text-muted mb-0">Vista de actas para uno o varios cursos.</p>
            </div>
            <a href="/ciie/calificaciones" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver a calificaciones
            </a>
        </div>

        <% if (cursosDocumentos && cursosDocumentos.length > 0) { %>
            <% cursosDocumentos.forEach(data => { %>
                <div class="card bg-dark border-secondary shadow-sm mb-4 acta-sheet">
                    <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                        <div>
                            <h5 class="mb-1"><%= data.curso?.nombrePropuesta || 'Curso' %></h5>
                            <small class="text-muted">
                                Oferta: <%= data.curso?.idOfertaOficial || '-' %>
                                | Formador: <%= data.curso?.formadorAbc || 'Sin formador' %>
                            </small>
                        </div>
                        <div class="d-flex gap-2">
                            <% if (data.curso?.impresionDocumentos?.actaImpresa) { %>
                                <span class="badge bg-success">Acta impresa</span>
                            <% } else { %>
                                <span class="badge bg-secondary">Pendiente impresión</span>
                            <% } %>
                            <button class="btn btn-outline-warning btn-sm btn-marcar-impreso" data-curso-id="<%= data.curso?.idOfertaOficial %>" data-tipo="acta">
                                <i class="bi bi-printer me-1"></i>Marcar impresa
                            </button>
                        </div>
                    </div>
                    <div class="card-body bg-white text-dark">
                        <div class="row g-2 small mb-3 text-secondary no-print">
                            <div class="col-md-2">Resolución: <strong class="text-dark"><%= data.administrativos?.resolucion || '-' %></strong></div>
                            <div class="col-md-2">Proyecto: <strong class="text-dark"><%= data.administrativos?.proyecto || '-' %></strong></div>
                            <div class="col-md-2">Dictamen: <strong class="text-dark"><%= data.administrativos?.dictamen || '-' %></strong></div>
                            <div class="col-md-2">Puntaje: <strong class="text-dark"><%= data.administrativos?.puntaje || '-' %></strong></div>
                            <div class="col-md-2">Horas: <strong class="text-dark"><%= data.administrativos?.horas || '-' %></strong></div>
                        </div>

                        <% if (data.acta && data.acta.length > 0) { %>
                            <table class="acta-table">
                                <thead>
                                    <tr>
                                        <th>Orden</th>
                                        <th>Apellido y nombre</th>
                                        <th>DNI</th>
                                        <th>Resultado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% data.acta.forEach(item => { %>
                                        <tr class="acta-row">
                                            <td><%= item.orden %></td>
                                            <td><%= item.nombreCompleto || '-' %></td>
                                            <td><%= item.dni || '-' %></td>
                                            <td><%= item.calificacion || 'Sin Calificar' %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        <% } else { %>
                            <div class="alert alert-secondary">No hay filas para mostrar en el acta.</div>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="alert alert-secondary">No hay cursos para mostrar.</div>
        <% } %>
    </div>

    <%- include('../../partials/scripts') %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function marcarImpresion(cursoId, tipo) {
            try {
                const response = await fetch(`/ciie/calificaciones/${cursoId}/documentos/impresion`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ tipo })
                });
                const result = await response.json();
                if (!result.success) throw new Error(result.error || 'No se pudo guardar el estado.');
                await Swal.fire('Listo', 'Estado de impresión actualizado.', 'success');
                window.location.reload();
            } catch (error) {
                Swal.fire('Error', error.message, 'error');
            }
        }

        $(document).on('click', '.btn-marcar-impreso', async function () {
            const cursoId = $(this).data('curso-id');
            const tipo = $(this).data('tipo');
            const confirm = await Swal.fire({
                icon: 'question',
                title: 'Confirmar impresión',
                text: 'Se guardará que el acta ya fue impresa.',
                showCancelButton: true,
                confirmButtonText: 'Sí, guardar',
                cancelButtonText: 'Cancelar'
            });
            if (!confirm.isConfirmed) return;
            await marcarImpresion(cursoId, tipo);
        });
    </script>
</body>
</html>
