<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <%- include('../../partials/head') %>
    <title>SICAA - Vincular Cursos Oficiales</title>
</head>
<body>
    <%- include('../../partials/navbar') %>
    <%- include('../../partials/msj') %>

    <div class="container py-5">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <h2 class="fw-bold mb-1">
                    <i class="bi bi-link-45deg me-2 text-primary"></i>Vincular Cursos con Sitio Oficial
                </h2>
                <p class="text-muted mb-0">Flujo A: vincular con oferta existente en ABC. Flujo B: crear oferta en ABC y luego vincular automaticamente.</p>
            </div>
            <a href="/ciie/cursos" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver a cursos
            </a>
        </div>

        <div class="card bg-dark border-secondary shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="tablaPendientes" class="table table-dark table-hover align-middle mb-0">
                        <thead class="small text-uppercase text-muted">
                            <tr>
                                <th>Curso Local</th>
                                <th>Cargo</th>
                                <th>Anio/Cohorte</th>
                                <th>Estado</th>
                                <th class="text-end pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (cursosPendientes && cursosPendientes.length > 0) { %>
                                <% cursosPendientes.forEach(curso => { %>
                                    <tr>
                                        <td>
                                            <div class="fw-semibold"><%= curso.nombrePropuesta || 'Sin nombre' %></div>
                                            <small class="text-muted"><%= curso.dispositivo || 'Sin dispositivo' %></small>
                                        </td>
                                        <td>
                                            <small><%= curso.cargoId?.areaId?.nombre || 'Area sin definir' %></small>
                                        </td>
                                        <td>
                                            <span><%= curso.anio || '-' %> / C<%= curso.cohorte ?? 0 %></span>
                                        </td>
                                        <td>
                                            <span class="badge bg-warning text-dark"><%= curso.estado || 'pendiente' %></span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="d-flex justify-content-end gap-2">
                                                <button
                                                    class="btn btn-primary btn-sm btn-vincular-oficial"
                                                    data-curso-id="<%= curso._id %>"
                                                    data-curso-nombre="<%= (curso.nombrePropuesta || 'Sin nombre').replace(/"/g, '&quot;') %>">
                                                    <i class="bi bi-link me-1"></i>Vincular Existente
                                                </button>
                                                <button
                                                    class="btn btn-success btn-sm btn-crear-oficial"
                                                    data-curso-id="<%= curso._id %>"
                                                    data-curso-nombre="<%= (curso.nombrePropuesta || 'Sin nombre').replace(/"/g, '&quot;') %>">
                                                    <i class="bi bi-cloud-upload me-1"></i>Crear en ABC
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        No hay cursos pendientes de vinculacion con el sitio oficial.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalVincularOficial" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content bg-dark border-primary">
                <div class="modal-header border-primary">
                    <h5 class="modal-title">
                        <i class="bi bi-cloud-check me-2"></i>Seleccionar Oferta Oficial
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="cursoLocalIdSeleccionado">

                    <div class="alert alert-secondary py-2 mb-3">
                        Curso local: <strong id="nombreCursoSeleccionado"></strong>
                    </div>

                    <div class="mb-3">
                        <input id="buscarOfertaOficial" class="form-control bg-dark border-secondary text-white" placeholder="Buscar oferta oficial por ID, nombre, dispositivo o formador...">
                    </div>

                    <div class="table-responsive">
                        <table class="table table-dark table-sm align-middle" id="tablaOfertasOficiales">
                            <thead class="small text-uppercase text-muted">
                                <tr>
                                    <th>ID Oferta</th>
                                    <th>Nombre</th>
                                    <th>Dispositivo</th>
                                    <th>Inicio</th>
                                    <th>Accion</th>
                                </tr>
                            </thead>
                            <tbody id="bodyOfertasOficiales"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script id="ofertasOficialesJson" type="application/json"><%- JSON.stringify(ofertasOficiales || []) %></script>
    <%- include('../../partials/scripts') %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const OFERTAS = JSON.parse(document.getElementById('ofertasOficialesJson').textContent || '[]');

        function renderOfertas(q = '') {
            const query = (q || '').toLowerCase();
            const tbody = document.getElementById('bodyOfertasOficiales');
            tbody.innerHTML = '';

            const filtradas = OFERTAS.filter(o => {
                const texto = [o.idOfertaOficial, o.nombrePropuesta, o.dispositivo, o.formadorAbc].join(' ').toLowerCase();
                return texto.includes(query);
            });

            if (filtradas.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">No hay ofertas que coincidan.</td></tr>';
                return;
            }

            filtradas.forEach(oferta => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><span class="badge bg-secondary">${oferta.idOfertaOficial || '-'}</span></td>
                    <td>${oferta.nombrePropuesta || '-'}</td>
                    <td>${oferta.dispositivo || '-'}</td>
                    <td>${oferta.fechaInicioCurso || '-'}</td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm btn-confirmar-vinculo"
                            data-id-oferta="${oferta.idOfertaOficial || ''}"
                            data-raw='${JSON.stringify(oferta.raw || []).replace(/'/g, '&#39;')}'>
                            Vincular
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        $(document).ready(function () {
            $('#tablaPendientes').DataTable({
                language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                pageLength: 10,
                order: [[2, 'desc']]
            });

            renderOfertas('');

            $('#buscarOfertaOficial').on('input', function () {
                renderOfertas(this.value);
            });

            $(document).on('click', '.btn-vincular-oficial', function () {
                const cursoId = $(this).data('curso-id');
                const nombre = $(this).data('curso-nombre');
                $('#cursoLocalIdSeleccionado').val(cursoId);
                $('#nombreCursoSeleccionado').text(nombre || '');
                const modal = new bootstrap.Modal(document.getElementById('modalVincularOficial'));
                modal.show();
            });

            $(document).on('click', '.btn-confirmar-vinculo', async function () {
                const cursoLocalId = $('#cursoLocalIdSeleccionado').val();
                const idOfertaOficial = $(this).data('id-oferta');
                let ofertaRaw = $(this).data('raw');

                if (typeof ofertaRaw === 'string') {
                    try {
                        ofertaRaw = JSON.parse(ofertaRaw);
                    } catch (e) {
                        ofertaRaw = [];
                    }
                }

                if (!cursoLocalId || !idOfertaOficial) {
                    Swal.fire('Atencion', 'Faltan datos para vincular.', 'warning');
                    return;
                }

                try {
                    const response = await fetch('/ciie/cursos/nuevo/vincular', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ cursoLocalId, idOfertaOficial, ofertaRaw })
                    });
                    const result = await response.json();

                    if (!result.success) {
                        throw new Error(result.error || 'No se pudo vincular.');
                    }

                    await Swal.fire({
                        icon: 'success',
                        title: 'Curso vinculado',
                        text: 'La oferta oficial fue asociada correctamente.',
                        timer: 1600,
                        showConfirmButton: false
                    });

                    location.reload();
                } catch (error) {
                    Swal.fire('Error', error.message, 'error');
                }
            });

            $(document).on('click', '.btn-crear-oficial', async function () {
                const cursoLocalId = $(this).data('curso-id');
                const nombre = $(this).data('curso-nombre');

                const confirm = await Swal.fire({
                    icon: 'question',
                    title: 'Crear oferta en ABC',
                    text: `Se va a crear y vincular la oferta oficial para: ${nombre}`,
                    showCancelButton: true,
                    confirmButtonText: 'Si, crear y vincular',
                    cancelButtonText: 'Cancelar'
                });

                if (!confirm.isConfirmed) return;

                try {
                    const response = await fetch('/ciie/cursos/nuevo/publicar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ cursoLocalId })
                    });

                    const result = await response.json();
                    if (!result.success) {
                        throw new Error(result.error || 'No se pudo crear la oferta oficial.');
                    }

                    await Swal.fire({
                        icon: 'success',
                        title: 'Curso creado en ABC',
                        text: `ID Oficial generado: ${result.abc?.idOfertaOficial || 'sin dato'}`,
                        timer: 1800,
                        showConfirmButton: false
                    });

                    location.reload();
                } catch (error) {
                    Swal.fire('Error', error.message, 'error');
                }
            });
        });
    </script>
</body>
</html>
